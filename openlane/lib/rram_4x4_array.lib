    }

    /* Bit Lines - RRAM top electrode (column access) */
    pin (BL[0]) {
      direction : inout ;
      capacitance : 0.000063 ;
      max_transition : 10.0 ;
      timing () {
        timing_type : min_pulse_width ;
        related_pin : "BL[0]" ;
        rise_constraint (scalar) { values ("1000.0") ; }
