library (rram_4x4_array_lib) {

  /* Library attributes */
  technology (cmos) ;
  delay_model : table_lookup ;
  time_unit : "1ns" ;
  voltage_unit : "1V" ;
  current_unit : "1mA" ;
  capacitive_load_unit (1, pf) ;
  pulling_resistance_unit : "1kohm" ;
  leakage_power_unit : "1nW" ;

  /* Operating conditions */
  nom_process : 1.0 ;
  nom_temperature : 25.0 ;
