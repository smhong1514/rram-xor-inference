  default_fanout_load : 1.0 ;

  cell (rram_4x4_array) {
    area : 434.73 ;  /* 17.33 x 25.35 um² */
    dont_touch : true ;
    dont_use : true ;
    is_macro_cell : true ;

    /* Word Lines - Gate control for row selection */
    pin (WL[0]) {
      direction : input ;
      capacitance : 0.000066 ;
      max_transition : 10.0 ;
      timing () {
        timing_type : min_pulse_width ;
        related_pin : "WL[0]" ;
        rise_constraint (scalar) { values ("1000.0") ; }
        fall_constraint (scalar) { values ("1000.0") ; }
      }
    }

