            "0.14890, 0.15903, 0.18463, 0.24111, 0.37531, 0.76582, 1.42404", \
            "0.22969, 0.24525, 0.28517, 0.37456, 0.54847, 0.93700, 1.67284", \
            "0.36837, 0.39097, 0.44988, 0.58622, 0.86119, 1.35227, 2.25459" \
          );
        }
        rise_transition (delay_template_7x7) {
          values ( \
            "0.04044, 0.04874, 0.07395, 0.14830, 0.36670, 1.00694, 2.99128", \
            "0.04023, 0.04866, 0.07377, 0.14822, 0.36661, 1.00686, 2.98815", \
            "0.03936, 0.04795, 0.07343, 0.14801, 0.36648, 1.00676, 2.98147", \
