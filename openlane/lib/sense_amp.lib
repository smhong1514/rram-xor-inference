            "0.05210, 0.08228, 0.15953, 0.34337, 0.78364, 1.90247, 5.10555" \
          );
        }
        fall_transition (delay_template_7x7) {
          values ( \
            "0.06862, 0.08683, 0.14067, 0.29836, 0.76008, 2.11284, 6.07552", \
            "0.06881, 0.08699, 0.14075, 0.29836, 0.76003, 2.11278, 6.07545", \
            "0.06892, 0.08707, 0.14074, 0.29820, 0.75977, 2.11247, 6.07512", \
            "0.07357, 0.09053, 0.14188, 0.29778, 0.75914, 2.11172, 6.07433", \
            "0.08505, 0.10286, 0.15411, 0.30223, 0.75750, 2.10980, 6.07227", \
            "0.10707, 0.12594, 0.17977, 0.33086, 0.76607, 2.10509, 6.06705", \
            "0.15938, 0.17932, 0.23629, 0.39441, 0.83361, 2.11535, 6.05463" \
          );
        }
      }
    }

    pin (QB) {
      direction : output;
      max_capacitance : 0.5;

      timing () {
        related_pin : "SAE";
        timing_sense : negative_unate;

        cell_rise (delay_template_7x7) {
          values ( \
            "0.04949, 0.05556, 0.07253, 0.11985, 0.25452, 0.64483, 1.24602", \
            "0.05381, 0.05991, 0.07702, 0.12449, 0.25928, 0.64965, 1.25325", \
            "0.06590, 0.07194, 0.08899, 0.13660, 0.27162, 0.66214, 1.27165", \
            "0.09679, 0.10318, 0.11999, 0.16724, 0.30230, 0.69305, 1.31717", \
