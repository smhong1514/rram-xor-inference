            "0.17988, 0.20383, 0.26350, 0.39076, 0.62365, 1.11512, 2.89364" \
          );
        }
        cell_fall (delay_template_7x7) {
          values ( \
            "0.07464, 0.08998, 0.13422, 0.26215, 0.63560, 1.72929, 4.93285", \
            "0.07807, 0.09360, 0.13814, 0.26633, 0.63991, 1.73365, 4.93723", \
            "0.08374, 0.09929, 0.14412, 0.27275, 0.64662, 1.74048, 4.94411", \
