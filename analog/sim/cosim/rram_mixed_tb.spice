XM33 n33 WL3 SL3 GND sky130_fd_pr__nfet_g5v0d10v5 L=0.5 W=1.5 nf=1 ad=0.435 as=0.435
+ pd=3.58 ps=3.58 nrd=0.193 nrs=0.193 sa=0 sb=0 sd=0 mult=1
.ends rram_4x4_fixed

** ========================================================
** TESTBENCH - PWL stimulus mimicking controller FSM
** ========================================================
** FSM timing (50MHz clk = 20ns period, read row=0):
**   t=0:    Reset
**   t=80ns: DECODE → WL_IN0, SL_EN0 go HIGH
**   t=100ns: READ_SENSE → SAE HIGH (BL precharge OFF)
**   t=180ns: READ_DONE → SAE LOW, SA result captured
**   t=200ns: IDLE → WL_IN0, SL_EN0 go LOW
** ========================================================

** Power supplies
VDD vdd 0 DC 1.8
VWL_PWR vwl_pwr 0 DC 3.3
VREF vref 0 DC 0.9

** --------------------------------------------------------
** Controller output stimulus (PWL)
** --------------------------------------------------------
* WL select[0]: active during DECODE → READ_DONE (80ns-200ns)
V_WL_IN0 wl_in0 0 PWL(0 0 79n 0 80n 1.8 199n 1.8 200n 0)
V_WL_IN1 wl_in1 0 DC 0
V_WL_IN2 wl_in2 0 DC 0
V_WL_IN3 wl_in3 0 DC 0

* SL enable[0]: active during DECODE → READ_DONE (same as WL)
V_SL_EN0 sl_en0 0 PWL(0 0 79n 0 80n 1.8 199n 1.8 200n 0)
V_SL_EN1 sl_en1 0 DC 0
V_SL_EN2 sl_en2 0 DC 0
V_SL_EN3 sl_en3 0 DC 0

* SAE (read_en): active during READ_SENSE → just before READ_DONE (100ns-180ns)
* SAE=0: precharge phase (BL charged to VDD, SA outputs precharged to VDD)
* SAE=1: evaluate phase (BL discharges through RRAM, SA senses)
V_SAE sae_a 0 PWL(0 0 99n 0 100n 1.8 179n 1.8 180n 0)

* BL write path: disabled for read operation
V_BLEN0 bl_en_a0 0 DC 0
V_BLEN1 bl_en_a1 0 DC 0
V_BLEN2 bl_en_a2 0 DC 0
V_BLEN3 bl_en_a3 0 DC 0
V_BLD0  bl_data_a0 0 DC 0
V_BLD1  bl_data_a1 0 DC 0
V_BLD2  bl_data_a2 0 DC 0
V_BLD3  bl_data_a3 0 DC 0

** --------------------------------------------------------
** WL Drivers (4x, one per row)
** Pins: IN OUT VDD VWL VSS
** --------------------------------------------------------
x_wld0 wl_in0 wl0 vdd vwl_pwr 0 wl_driver
x_wld1 wl_in1 wl1 vdd vwl_pwr 0 wl_driver
x_wld2 wl_in2 wl2 vdd vwl_pwr 0 wl_driver
x_wld3 wl_in3 wl3 vdd vwl_pwr 0 wl_driver

** --------------------------------------------------------
** BL precharge PMOS (gate=wl_in0: precharge OFF when WL activates)
** This gives BL time to develop differential BEFORE SA evaluates
** --------------------------------------------------------
XMP_pre0 bl0 wl_in0 vdd vdd sky130_fd_pr__pfet_01v8 L=0.15 W=2 nf=1 ad=0.58 as=0.58
+ pd=4.58 ps=4.58 nrd=0.145 nrs=0.145 sa=0 sb=0 sd=0 mult=1
XMP_pre1 bl1 wl_in0 vdd vdd sky130_fd_pr__pfet_01v8 L=0.15 W=2 nf=1 ad=0.58 as=0.58
+ pd=4.58 ps=4.58 nrd=0.145 nrs=0.145 sa=0 sb=0 sd=0 mult=1
XMP_pre2 bl2 wl_in0 vdd vdd sky130_fd_pr__pfet_01v8 L=0.15 W=2 nf=1 ad=0.58 as=0.58
+ pd=4.58 ps=4.58 nrd=0.145 nrs=0.145 sa=0 sb=0 sd=0 mult=1
XMP_pre3 bl3 wl_in0 vdd vdd sky130_fd_pr__pfet_01v8 L=0.15 W=2 nf=1 ad=0.58 as=0.58
+ pd=4.58 ps=4.58 nrd=0.145 nrs=0.145 sa=0 sb=0 sd=0 mult=1

** BL parasitic capacitance (100fF per BL - realistic for small array)
C_bl0 bl0 0 100f
C_bl1 bl1 0 100f
C_bl2 bl2 0 100f
C_bl3 bl3 0 100f

** --------------------------------------------------------
** SL ground switches (NFET: SL → GND when sl_en is high)
** --------------------------------------------------------
XMN_sl0 rram_sl0 sl_en0 0 0 sky130_fd_pr__nfet_01v8 L=0.15 W=10 nf=1 ad=2.9 as=2.9
+ pd=20.58 ps=20.58 nrd=0.029 nrs=0.029 sa=0 sb=0 sd=0 mult=1
XMN_sl1 rram_sl1 sl_en1 0 0 sky130_fd_pr__nfet_01v8 L=0.15 W=10 nf=1 ad=2.9 as=2.9
+ pd=20.58 ps=20.58 nrd=0.029 nrs=0.029 sa=0 sb=0 sd=0 mult=1
XMN_sl2 rram_sl2 sl_en2 0 0 sky130_fd_pr__nfet_01v8 L=0.15 W=10 nf=1 ad=2.9 as=2.9
+ pd=20.58 ps=20.58 nrd=0.029 nrs=0.029 sa=0 sb=0 sd=0 mult=1
XMN_sl3 rram_sl3 sl_en3 0 0 sky130_fd_pr__nfet_01v8 L=0.15 W=10 nf=1 ad=2.9 as=2.9
+ pd=20.58 ps=20.58 nrd=0.029 nrs=0.029 sa=0 sb=0 sd=0 mult=1

** --------------------------------------------------------
** BL write drivers (NFET pass: connects bl_data to BL when bl_en high)
** --------------------------------------------------------
XMN_blw0 bl0 bl_en_a0 bl_data_a0 0 sky130_fd_pr__nfet_01v8 L=0.15 W=5 nf=1 ad=1.45 as=1.45
+ pd=10.58 ps=10.58 nrd=0.058 nrs=0.058 sa=0 sb=0 sd=0 mult=1
XMN_blw1 bl1 bl_en_a1 bl_data_a1 0 sky130_fd_pr__nfet_01v8 L=0.15 W=5 nf=1 ad=1.45 as=1.45
+ pd=10.58 ps=10.58 nrd=0.058 nrs=0.058 sa=0 sb=0 sd=0 mult=1
XMN_blw2 bl2 bl_en_a2 bl_data_a2 0 sky130_fd_pr__nfet_01v8 L=0.15 W=5 nf=1 ad=1.45 as=1.45
+ pd=10.58 ps=10.58 nrd=0.058 nrs=0.058 sa=0 sb=0 sd=0 mult=1
XMN_blw3 bl3 bl_en_a3 bl_data_a3 0 sky130_fd_pr__nfet_01v8 L=0.15 W=5 nf=1 ad=1.45 as=1.45
+ pd=10.58 ps=10.58 nrd=0.058 nrs=0.058 sa=0 sb=0 sd=0 mult=1

** --------------------------------------------------------
** RRAM 4x4 Array
** --------------------------------------------------------
x_rram bl0 bl1 bl2 bl3 wl0 wl1 wl2 wl3 rram_sl0 rram_sl1 rram_sl2 rram_sl3 0 rram_4x4_fixed

** --------------------------------------------------------
** Sense Amplifiers (4x, one per BL)
** Pins: SAE INP INN Q QB VDD VSS
** --------------------------------------------------------
x_sa0 sae_a bl0 vref sa_q0 sa_qb0 vdd 0 sense_amp
x_sa1 sae_a bl1 vref sa_q1 sa_qb1 vdd 0 sense_amp
x_sa2 sae_a bl2 vref sa_q2 sa_qb2 vdd 0 sense_amp
x_sa3 sae_a bl3 vref sa_q3 sa_qb3 vdd 0 sense_amp

** --------------------------------------------------------
** Simulation control
** --------------------------------------------------------
.control
pre_osdi $PDK_ROOT/sky130B/libs.tech/ngspice/sky130_fd_pr_reram__reram_module.osdi
save all
tran 0.1n 300n
remzerovec
write rram_mixed_tb.raw

echo ""
echo "============================================"
echo "RRAM Mixed-Signal Simulation Complete"
echo "============================================"
echo "Test: Read Row=0 (pre-programmed: LRS,HRS,LRS,HRS)"
echo ""

* Measure SA outputs at t=150ns (during evaluate phase)
meas tran sa_q0_val FIND v(sa_q0) AT=150n
meas tran sa_q1_val FIND v(sa_q1) AT=150n
meas tran sa_q2_val FIND v(sa_q2) AT=150n
meas tran sa_q3_val FIND v(sa_q3) AT=150n

* Measure BL voltages at t=150ns
meas tran bl0_val FIND v(bl0) AT=150n
meas tran bl1_val FIND v(bl1) AT=150n
meas tran bl2_val FIND v(bl2) AT=150n
meas tran bl3_val FIND v(bl3) AT=150n

* Measure WL driver output
meas tran wl0_val FIND v(wl0) AT=150n

echo ""
echo "Expected: SA_Q0=HIGH(LRS), SA_Q1=LOW(HRS), SA_Q2=HIGH(LRS), SA_Q3=LOW(HRS)"
echo "============================================"

* Save CSV for plotting
wrdata rram_mixed_tb.csv v(wl_in0) v(wl0) v(sae_a)
+ v(bl0) v(bl1) v(bl2) v(bl3)
+ v(sa_q0) v(sa_q1) v(sa_q2) v(sa_q3)
+ v(sa_qb0) v(sa_qb1) v(sa_qb2) v(sa_qb3)
+ v(rram_sl0) v(sl_en0)

.endc
.end
